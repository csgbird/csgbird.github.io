---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { id: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

// 没有 frontmatter title 时，从 id 推断标题（去掉扩展名，替换连字符）
const title = note.data.title ?? note.id.replace(/\.md$/, '').replace(/[-_]/g, ' ');
---

<BaseLayout title={`${title} - C雙G 笔记`} description={note.data.description}>
  <div class="note-layout">
    <article class="note-content">
      <header class="note-header">
        <a href="/notes" class="back-link">← 笔记</a>
        <h1>{title}</h1>
        {note.data.description && <p class="note-desc">{note.data.description}</p>}
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>

    {headings.length > 0 && (
      <aside class="toc">
        <div class="toc-inner">
          <p class="toc-title">目录</p>
          <nav>
            <ul>
              {headings.map(h => (
                <li class={`toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .note-layout {
    max-width: calc(var(--max-width) + 260px);
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .note-content { flex: 1; min-width: 0; }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-primary); text-decoration: none; }

  .note-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .note-header h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .note-desc { color: var(--color-text-muted); font-size: 0.95rem; }

  /* 正文样式 */
  .prose { line-height: 1.85; font-size: 1rem; }

  .prose :global(h1) { display: none; } /* 已在 header 显示 */

  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--color-primary);
  }

  .prose :global(p) { margin-bottom: 1.25rem; }

  .prose :global(ul), .prose :global(ol) {
    margin: 0.75rem 0 1.25rem 1.5rem;
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-soft);
    padding: 0.75rem 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    background: var(--color-bg-soft);
    padding: 0.6rem 1rem;
    text-align: left;
    border: 1px solid var(--color-border);
    font-weight: 600;
  }

  .prose :global(td) {
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-border);
  }

  .prose :global(tr:nth-child(even) td) {
    background: var(--color-bg-soft);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  /* 右侧目录 */
  .toc {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
  }

  .toc-inner {
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }

  .toc-title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .toc nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.2rem; }

  .toc-item a {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: block;
    padding: 0.2rem 0;
    transition: color 0.15s;
    line-height: 1.4;
  }
  .toc-item a:hover { color: var(--color-primary); text-decoration: none; }

  .toc-item.depth-3 { padding-left: 0.75rem; }
  .toc-item.depth-4 { padding-left: 1.5rem; }

  @media (max-width: 900px) { .toc { display: none; } }
</style>
