---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allNotes = await getCollection('notes');

// 按 category frontmatter 分组，没有则归入「未分类」
type Note = typeof allNotes[0];
const grouped = new Map<string, Note[]>();

for (const note of allNotes) {
  const cat = note.data.category ?? '未分类';
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(note);
}

// 图标映射
const catIcons: Record<string, string> = {
  'Java': '☕', '前端': '🌐', '数据库': '🗄️',
  '工具': '🔧', '算法': '🧮', '读书': '📖', '未分类': '📄',
};
---

<BaseLayout title="笔记 - C雙G">
  <div class="notes-container">
    <div class="page-header fade-in-up">
      <h1 class="page-title">笔记</h1>
      <p class="page-desc">
        系统整理的知识库，从 Obsidian 同步。
        共 <strong>{allNotes.length}</strong> 篇。
      </p>
    </div>

    {allNotes.length === 0 ? (
      <p class="empty-hint">
        还没有笔记。把 <code>.md</code> 文件放到
        <code>~/notebook/wiki/</code> 目录里，下次 commit 时会自动同步。
      </p>
    ) : (
      <div class="notes-body">
        {[...grouped.entries()].map(([cat, notes]) => (
          <section class="cat-section scroll-fade">
            <h2 class="cat-title">
              <span class="cat-icon">{catIcons[cat] ?? '📄'}</span>
              {cat}
              <span class="cat-count">{notes.length}</span>
            </h2>
            <ul class="note-list">
              {notes.map((note) => {
                const title = note.data.title ?? note.id.replace(/[-_]/g, ' ');
                return (
                  <li class="note-item">
                    <a href={`/notes/${note.id}`} class="note-link">
                      <span class="note-title">{title}</span>
                      {note.data.description && (
                        <span class="note-desc">{note.data.description}</span>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </section>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.scroll-fade').forEach(el => observer.observe(el));
</script>

<style>
  .notes-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .page-desc { color: var(--color-text-muted); font-size: 0.95rem; }
  .page-desc strong { color: var(--color-primary); }

  .empty-hint {
    color: var(--color-text-muted);
    padding: 2rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
    text-align: center;
  }

  .notes-body { display: flex; flex-direction: column; gap: 2.5rem; }

  /* 分类区块 */
  .cat-section {}

  .cat-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .cat-icon { font-size: 1.1rem; }

  .cat-count {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 400;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.5rem;
    border-radius: 100px;
  }

  /* 笔记列表 */
  .note-list { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }

  .note-item {}

  .note-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s, color 0.15s;
    flex-wrap: wrap;
  }
  .note-link:hover {
    background: var(--color-bg-soft);
    color: var(--color-primary);
    text-decoration: none;
  }

  .note-title { font-size: 0.95rem; font-weight: 500; }

  .note-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    flex: 1;
  }
</style>
